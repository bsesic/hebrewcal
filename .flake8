# flake8 is the lint gate that must pass before every commit.
# Line length and ignores are aligned with ruff (configured in pyproject.toml)
# so the two linters agree.
[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    docs/_build
per-file-ignores =
    __init__.py: F401
